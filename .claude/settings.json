{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "MultiEdit(*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/goat/Desktop/_CENTRAL/MyFrot/execution/frontend && npm run build 2>&1 | tail -10 | grep -E 'error|warning|built|Error' || echo 'Build OK'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[AUDITORIA] Comando executado em: '$(date '+%Y-%m-%d %H:%M:%S') >> /Users/goat/Desktop/_CENTRAL/MyFrot/auditorias/log-comandos.txt 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git status --short | head -10"
          }
        ]
      }
    ]
  }
}
